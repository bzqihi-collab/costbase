{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": { "@shared/*": ["shared/*"] },
    "skipLibCheck": true
  },
  "include": ["src/**/*", "electron/**/*", "shared/**/*"],
  "exclude": ["node_modules", "dist", "dist-electron"]
}
